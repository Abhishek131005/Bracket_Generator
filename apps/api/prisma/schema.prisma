// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tournament {
  id               String   @id @default(cuid())
  name             String
  sportId          Int
  sportName        String
  format           String
  rankingRule      String
  status           String   @default("DRAFT")
  description      String?
  maxParticipants  Int?
  scheduledStartAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  participants Participant[]
  stages       Stage[]

  @@index([status])
  @@index([sportId])
}

model Participant {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  seed         Int?
  type         String     @default("TEAM")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  fixturesAsLeft       Fixture[]          @relation("FixtureLeft")
  fixturesAsRight      Fixture[]          @relation("FixtureRight")
  autoAdvancedFixtures Fixture[]          @relation("FixtureAutoAdvance")
  performanceEntries   PerformanceEntry[]

  @@unique([tournamentId, name])
  @@unique([tournamentId, seed])
  @@index([tournamentId])
}

model Stage {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name         String
  sequence     Int
  format       String
  rankingRule  String
  status       String     @default("DRAFT")
  config       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  fixtures           Fixture[]
  performanceEntries PerformanceEntry[]

  @@unique([tournamentId, sequence])
  @@index([tournamentId, status])
}

model Fixture {
  id                       String       @id @default(cuid())
  stageId                  String
  stage                    Stage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  code                     String?
  bracket                  String?
  roundIndex               Int
  matchIndex               Int
  leftParticipantId        String?
  rightParticipantId       String?
  leftParticipant          Participant? @relation("FixtureLeft", fields: [leftParticipantId], references: [id], onDelete: SetNull)
  rightParticipant         Participant? @relation("FixtureRight", fields: [rightParticipantId], references: [id], onDelete: SetNull)
  leftLabel                String?
  rightLabel               String?
  winnerGoesTo             String?
  loserGoesTo              String?
  leftScore                Float?
  rightScore               Float?
  status                   String       @default("SCHEDULED")
  autoAdvanceParticipantId String?
  autoAdvanceParticipant   Participant? @relation("FixtureAutoAdvance", fields: [autoAdvanceParticipantId], references: [id], onDelete: SetNull)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  performanceEntries PerformanceEntry[]

  @@unique([stageId, roundIndex, matchIndex])
  @@unique([stageId, code])
  @@index([stageId, roundIndex])
  @@index([stageId, status])
}

enum Role {
  ADMIN
  ORGANIZER
  REFEREE
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model PerformanceEntry {
  id            String      @id @default(cuid())
  stageId       String
  stage         Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)
  fixtureId     String?
  fixture       Fixture?    @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  metricValue   Float
  unit          String?
  rank          Int?
  metadata      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([stageId, participantId])
  @@index([stageId, metricValue])
  @@index([fixtureId])
}
